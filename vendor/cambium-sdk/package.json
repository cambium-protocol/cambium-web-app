{
  "name": "@cambium-protocol/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for Cambium Protocol — carbon credit registry, marketplace, and retirement on Stellar/Soroban",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "jest --verbose",
    "test:unit": "jest --verbose test/unit",
    "test:integration": "jest --verbose test/integration",
    "lint": "eslint src/ test/",
    "clean": "rm -rf dist",
    "link:local-contracts": "node -e \"const fs=require('fs');const p=process.argv[2]||'../contracts/deployed-addresses.local.json';if(!fs.existsSync(p)){console.error('File not found:',p);process.exit(1)}fs.copyFileSync(p,'./deployed-addresses.local.json');console.log('Linked:',p)\""
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:cambium-protocol/cambium-sdk.git"
  },
  "keywords": [
    "stellar",
    "soroban",
    "carbon-credits",
    "cambium",
    "sdk"
  ],
  "author": "Cambium Protocol",
  "license": "Apache-2.0",
  "dependencies": {
    "@stellar/stellar-sdk": ">=12.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "eslint": "^9.39.5",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.64.0"
  },
  "peerDependencies": {
    "@stellar/stellar-sdk": ">=12.0.0"
  }
}
